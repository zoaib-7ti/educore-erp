<Window x:Class="SchoolERP.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School ERP - Login"
        Height="620"
        Width="1040"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#0F172A">
    <Window.Resources>
        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#111827" Offset="0" />
            <GradientStop Color="#1F2937" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#22C55E" Offset="0" />
            <GradientStop Color="#14B8A6" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,6,0,14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,6,0,14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Grid Background="#0F172A">
            <Grid Margin="64">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="School ERP" FontSize="42" FontWeight="Bold" Margin="0,0,0,14" />
                    <TextBlock Text="Finance, attendance, students, and staff in one secure desktop system." FontSize="17" Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,0,0,32" />

                    <Border Background="#111827" CornerRadius="18" Padding="18" Margin="0,0,0,16" Width="360">
                        <StackPanel>
                            <TextBlock Text="Offline-first" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Designed for stable local usage with SQL Server Express and biometric attendance support." Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="#111827" CornerRadius="18" Padding="18" Width="360">
                        <StackPanel>
                            <TextBlock Text="Role-based access" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Admin, accountant, receptionist, and teacher access paths are controlled at login." Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Background="#E2E8F0">
            <Border Margin="48" Background="White" CornerRadius="24" Padding="36" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Welcome Back" FontSize="30" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Text="Sign in to continue to the School ERP dashboard." Foreground="#475569" Margin="0,8,0,24" TextWrapping="Wrap" />

                    <TextBlock Text="Username" Foreground="#0F172A" FontWeight="SemiBold" />
                    <TextBox x:Name="UsernameTextBox" />

                    <TextBlock Text="Password" Foreground="#0F172A" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" />

                    <CheckBox x:Name="RememberMeCheckBox" Content="Remember me" Foreground="#334155" Margin="0,0,0,10" />

                    <Button x:Name="LoginButton" Content="Sign In" Click="LoginButton_Click">
                        <Button.Background>
                            <StaticResource ResourceKey="AccentGradient" />
                        </Button.Background>
                    </Button>

                    <TextBlock x:Name="StatusTextBlock" Foreground="#DC2626" Margin="0,14,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>