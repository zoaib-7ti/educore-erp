<Window x:Class="SchoolERP.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SchoolERP.Controls"
        xmlns:helpers="clr-namespace:SchoolERP.Helpers"
        Title="School ERP - Login"
        Height="760"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="NavyGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#001A3F" Offset="0" />
            <GradientStop Color="#0A234F" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SoftTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#001A3F" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="14" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A234F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#071C42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="White" CornerRadius="32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Grid Background="{StaticResource NavyGradient}">
                    <Grid Margin="56">
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="118" Height="118" Background="Transparent" Margin="0,0,0,22">
                                <Image Source="pack://application:,,,/Assets/logo.png" Width="64" Height="64" Stretch="Uniform" />
                            </Border>

                            <TextBlock Text="GRAMMAR PUBLIC SCHOOL, GHAZIKOT, MANSEHRA"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       LineHeight="38"
                                       Margin="0,0,0,14" />

                            <TextBlock Text="OFFICIAL ERP SYSTEM | Comprehensive School Management: Finance, Attendance, Students, Staff."
                                       FontSize="16"
                                       Foreground="{StaticResource SoftTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,30" />

                            <Border Background="#071C42" CornerRadius="18" Padding="18" Margin="0,0,0,16" Width="420" BorderBrush="#173562" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="42" Height="42" CornerRadius="21" Background="#0F2E61" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE928;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#14C78D" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Biometric Attendance" FontSize="19" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="Designed for stable local usage with biometric attendance support." FontSize="13.5" Foreground="{StaticResource SoftTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="#071C42" CornerRadius="18" Padding="18" Width="420" BorderBrush="#173562" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="42" Height="42" CornerRadius="21" Background="#0F2E61" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#14C78D" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Role-based access" FontSize="19" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="Admin, accountant, receptionist, and teacher access paths are controlled at login." FontSize="13.5" Foreground="{StaticResource SoftTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1" Background="#EEF2F7">
                    <Border Width="440"
                            Background="White"
                            CornerRadius="28"
                            Padding="38"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Welcome Back" FontSize="30" FontWeight="Bold" Foreground="#0F172A" />
                            <TextBlock Text="Sign in to continue to the School ERP dashboard." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,28" TextWrapping="Wrap" />

                            <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="30" CornerRadius="15" Background="#E8F1FB" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#001A3F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource InputBoxStyle}"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>

                            <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                            <Border Style="{StaticResource InputBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30" Height="30" CornerRadius="15" Background="#E8F1FB" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#001A3F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <PasswordBox Grid.Column="1"
                                                 Style="{StaticResource PasswordBoxStyle}"
                                                 helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>

                            <CheckBox Content="Remember me" Foreground="#334155" Margin="0,0,0,14" />

                            <Button Content="Sign In" Command="{Binding LoginCommand}" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />

                            <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" Margin="0,14,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
