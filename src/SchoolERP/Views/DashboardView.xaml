<UserControl x:Class="SchoolERP.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="0,0,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="2">
            <Border Background="White"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,14,14"
                    Height="110">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="46" Height="46" CornerRadius="14" Background="#E8F1FB" VerticalAlignment="Center">
                        <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Students" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="235" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,0,14"
                    Height="110">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="46" Height="46" CornerRadius="14" Background="#ECFDF5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Teachers" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="38" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,14,0"
                    Height="110">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="46" Height="46" CornerRadius="14" Background="#F0F9FF" VerticalAlignment="Center">
                        <TextBlock Text="&#xEAFD;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#0F9D58" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Fee Collected (Month)" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="Rs 12,500" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    CornerRadius="18"
                    Padding="18"
                    Height="110">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="46" Height="46" CornerRadius="14" Background="#FEF2F2" VerticalAlignment="Center">
                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Fees Outstanding" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="Rs 8,750" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Style="{StaticResource BodyCardStyle}">
            <StackPanel>
                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Staff Attendance"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="Teacher presence today"
                               Foreground="#64748B"
                               DockPanel.Dock="Right"/>
                </DockPanel>

                <UniformGrid Columns="2">
                    <Border Background="#F8FAFC"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,0,10,0"
                            Height="130">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Teacher Present Today" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock Text="28" FontSize="34" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FAFC"
                            CornerRadius="16"
                            Padding="18"
                            Margin="10,0,0,0"
                            Height="130">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Teacher Absent Today" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock Text="10" FontSize="34" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
