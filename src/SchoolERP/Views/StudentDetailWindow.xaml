<Window x:Class="SchoolERP.Views.StudentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Details"
        Height="600"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="#001A3F"
                    CornerRadius="20,20,0,0"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="{Binding Student.Name}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Student.RegistrationNo}"
                               FontSize="14"
                               Foreground="#D6E2F2"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Student info grid -->
            <Grid Grid.Row="1" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Father Name" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.FatherName}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Date of Birth" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.DOB, StringFormat='dd MMM yyyy'}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Class" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.ClassName}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.Phone}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.Address}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Admission Date" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.AdmissionDateDisplay}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Monthly Fee (Rs)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Text="{Binding Student.MonthlyFee, StringFormat='Rs {0:N0}'}" Style="{StaticResource FieldValueStyle}"/>
                </StackPanel>
            </Grid>

            <!-- Fee History -->
            <StackPanel Grid.Row="2" Margin="24,8,24,0">
                <TextBlock Text="Fee History"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           Margin="0,0,0,12"/>

                <DataGrid ItemsSource="{Binding FeeHistory}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E2E8F0"
                          BorderBrush="#E2E8F0"
                          BorderThickness="1"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC"
                          Background="White"
                          RowHeight="38"
                          ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="100"/>
                        <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeType}" Width="130"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='Rs {0:N0}'}" Width="100"/>
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="StatusBorder" CornerRadius="6" Padding="6,2" Margin="4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Paid">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Due">
                                            <Setter TargetName="StatusBorder" Property="Background" Value="#FF6B35"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDate, StringFormat='dd MMM yyyy'}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Text="{Binding SummaryText}"
                       Foreground="#64748B"
                       FontSize="13"
                       Margin="24,10,24,0"/>

            <Button Grid.Row="4"
                    Content="Close"
                    Width="100"
                    Height="38"
                    HorizontalAlignment="Right"
                    Margin="24,16,24,20"
                    Background="#001A3F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
