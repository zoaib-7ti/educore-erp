<Window x:Class="SchoolERP.Views.AddEditStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="480"
        SizeToContent="Height"
        MaxHeight="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Padding="28"
            Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding WindowTitle}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,18"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Full Name *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding NameError}" Style="{StaticResource ErrorTextStyle}"/>

                    <TextBlock Text="Designation *" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding Designation, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding DesignationError}" Style="{StaticResource ErrorTextStyle}"/>

                    <TextBlock Text="Base Salary *" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding SalaryText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding SalaryError}" Style="{StaticResource ErrorTextStyle}"/>

                    <TextBlock Text="Fingerprint ID" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding FingerprintIdText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding FingerprintIdError}" Style="{StaticResource ErrorTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Cancel"
                            Width="100"
                            Height="40"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"
                            Background="#F1F5F9"
                            Foreground="#334155"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="Save"
                            Width="100"
                            Height="40"
                            Command="{Binding SaveCommand}"
                            Background="#001A3F"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
