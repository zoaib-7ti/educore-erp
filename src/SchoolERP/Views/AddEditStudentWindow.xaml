<Window x:Class="SchoolERP.Views.AddEditStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="620"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FieldComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FieldDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Padding="28"
            Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,18"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Registration No *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding RegistrationNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding RegistrationNoError}" Style="{StaticResource ErrorTextStyle}"/>

                    <TextBlock Text="Full Name *" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>
                    <TextBlock Text="{Binding NameError}" Style="{StaticResource ErrorTextStyle}"/>

                    <TextBlock Text="Father Name" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding FatherName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>

                    <TextBlock Text="Date of Birth" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <DatePicker SelectedDate="{Binding DOB}" Style="{StaticResource FieldDateStyle}"/>

                    <TextBlock Text="Class" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <ComboBox ItemsSource="{Binding Classes}"
                              DisplayMemberPath="ClassName"
                              SelectedValuePath="ClassID"
                              SelectedValue="{Binding SelectedClassId}"
                              Style="{StaticResource FieldComboStyle}"/>

                    <TextBlock Text="Monthly Fee (Rs)" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox x:Name="MonthlyFeeTextBox"
                             Text="{Binding MonthlyFee, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldInputStyle}"
                             PreviewTextInput="MonthlyFeeTextBox_PreviewTextInput"/>

                    <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldInputStyle}"
                             Height="64"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInputStyle}"/>

                    <TextBlock Text="Admission Date" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6"/>
                    <DatePicker SelectedDate="{Binding AdmissionDate}" Style="{StaticResource FieldDateStyle}"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Cancel"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Command="{Binding CancelCommand}"
                        Background="#F1F5F9"
                        Foreground="#334155"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="Save"
                        Width="100"
                        Height="40"
                        Command="{Binding SaveCommand}"
                        Background="#001A3F"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
