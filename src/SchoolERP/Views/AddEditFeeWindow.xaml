<Window x:Class="SchoolERP.Views.AddEditFeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Payment"
        Width="520"
        SizeToContent="Height"
        MaxHeight="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FieldComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FieldDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Padding="24"
            Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock x:Name="TxtTitle"
                           Text="Record Payment"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,0,0,16"/>

                <!-- Form -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Student -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                        <TextBlock Text="Student *" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ComboStudent"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              DisplayMemberPath="Name"
                              Style="{StaticResource FieldComboStyle}"
                              SelectionChanged="ComboStudent_SelectionChanged"
                              PreviewTextInput="ComboStudent_PreviewTextInput"
                              DataObject.Pasting="ComboStudent_Pasting"/>
                    </StackPanel>

                    <!-- Row 1: Month | Fee Type -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                        <TextBlock Text="Month *" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ComboMonth" Style="{StaticResource FieldComboStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                        <TextBlock Text="Fee Type *" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ComboFeeType"
                                  Style="{StaticResource FieldComboStyle}"
                                  SelectionChanged="ComboFeeType_SelectionChanged">
                            <ComboBoxItem Content="Monthly Tuition"/>
                            <ComboBoxItem Content="Admission Fee"/>
                            <ComboBoxItem Content="Exam Fee"/>
                            <ComboBoxItem Content="Transport"/>
                            <ComboBoxItem Content="Other"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Row 2: Amount | Status -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                        <TextBlock Text="Amount *" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtAmount" Style="{StaticResource FieldInputStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                        <TextBlock Text="Status *" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ComboStatus"
                                  Style="{StaticResource FieldComboStyle}"
                                  SelectionChanged="ComboStatus_SelectionChanged">
                            <ComboBoxItem Content="Due"/>
                            <ComboBoxItem Content="Paid"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Row 3: Payment Date -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Payment Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker x:Name="DpPaymentDate" Height="34" Margin="0,4,0,0" Style="{StaticResource FieldDateStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="Cancel"
                            Width="90"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"
                            Background="#F1F5F9"
                            Foreground="#334155"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="Save"
                            Width="90"
                            Height="36"
                            Click="Save_Click"
                            Background="#001A3F"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
