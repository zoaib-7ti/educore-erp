<Window x:Class="SchoolERP.Views.FeeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fee Details"
        Height="420"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            Margin="16"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Fee Details"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,18"/>

            <Border Grid.Row="1"
                    Height="4"
                    CornerRadius="2"
                    Background="#001A3F"
                    Width="48"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"/>

            <Grid Grid.Row="2" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Student Name" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding StudentName}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Registration No" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding RegistrationNo}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Class" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding ClassName}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Month" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding Month}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Fee Type" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding FeeType}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Amount" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding Amount, StringFormat='Rs {0:N0}'}" Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Status" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock x:Name="StatusText" Text="{Binding Status}" FontSize="15" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF6B35"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Paid">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Payment Date" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding PaymentDate, StringFormat='{}{0:dd MMM yyyy}', TargetNullValue='—'}"
                                   Style="{StaticResource CardValueStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Button Grid.Row="3"
                    Content="Close"
                    Width="100"
                    Height="38"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    Background="#001A3F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
