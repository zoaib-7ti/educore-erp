<UserControl x:Class="SchoolERP.Views.FeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#001A3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0A234F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModuleDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- SECTION 1 — Action Bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <TextBlock Text="Fees"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" FlowDirection="RightToLeft" VerticalAlignment="Center">
                <Button Content="Add Fee"
                        Command="{Binding AddFeeCommand}"
                        Padding="16,10"
                        Margin="8,0,0,0"
                        Background="#22C55E"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13"
                        BorderThickness="0"
                        Cursor="Hand"
                        FlowDirection="LeftToRight">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Generate Monthly Fees"
                        Command="{Binding GenerateMonthlyFeesCommand}"
                        Padding="16,10"
                        Margin="8,0,0,0"
                        Background="#0F172A"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13"
                        BorderThickness="0"
                        Cursor="Hand"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                        FlowDirection="LeftToRight">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- SECTION 2 — Summary Cards -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- Card 1 — green accent -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#10B981" Padding="18,14" Margin="0,0,16,0" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Total Collected (This Month)" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalCollected, StringFormat='Rs {0:N0}'}" FontSize="20" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2 — red accent -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#EF4444" Padding="18,14" Margin="0,0,16,0" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Total Outstanding" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalOutstanding, StringFormat='Rs {0:N0}'}" FontSize="20" FontWeight="Bold" Foreground="#EF4444" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3 — blue accent -->
            <Border Background="White" CornerRadius="12" BorderThickness="4,1,1,1" BorderBrush="#3B82F6" Padding="18,14" Margin="0,0,16,0" Width="240" Height="82">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Total Records" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalRecords}" FontSize="20" FontWeight="Bold" Foreground="#3B82F6" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- SECTION 3 — Filter Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="260"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,6"
                    Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="#64748B"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Foreground="#0F172A"
                             FontSize="14"/>
                </DockPanel>
            </Border>

            <ComboBox Width="120" Height="36" SelectedValue="{Binding StatusFilter}" SelectedValuePath="Content" VerticalContentAlignment="Center" Margin="0,0,12,0">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Due"/>
                <ComboBoxItem Content="Paid"/>
            </ComboBox>

            <ComboBox Width="120" Height="36" ItemsSource="{Binding MonthOptions}" SelectedItem="{Binding DisplayMonthFilter}" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="FeeDataGrid"
                  Grid.Row="3"
                  ItemsSource="{Binding FilteredFees}"
                  Style="{StaticResource ModuleDataGridStyle}"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Reg No" Binding="{Binding RegistrationNo}" Width="110"/>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*"/>
                <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="100"/>
                <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="100"/>
                <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeType}" Width="120"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N0}}" Width="100"/>
                
                <DataGridTemplateColumn Header="Status" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="StatusBorder" CornerRadius="6" Padding="6,2" Margin="4" Width="70" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Paid">
                                    <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Due">
                                    <Setter TargetName="StatusBorder" Property="Background" Value="#FF6B35"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDate, StringFormat={}{0:dd MMM yyyy}}" Width="120"/>

                <DataGridTemplateColumn Header="Actions" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Mark Paid button -->
                                <Button x:Name="BtnMarkPaid" Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.MarkAsPaidCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Mark as Paid">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#10B981"/>
                                </Button>

                                <!-- Edit button -->
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.EditFeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Edit">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#3B82F6"/>
                                </Button>

                                <!-- Delete button -->
                                <Button Style="{StaticResource IconButtonStyle}"
                                        Command="{Binding DataContext.DeleteFeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Delete"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#DC2626"/>
                                </Button>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Paid">
                                    <Setter TargetName="BtnMarkPaid" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Due">
                                    <Setter TargetName="BtnMarkPaid" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom bar -->
        <TextBlock Grid.Row="4"
                   Text="{Binding TotalRecords, StringFormat='Showing {0} of {1} records'}"
                   Foreground="#64748B"
                   FontSize="13"
                   Margin="0,12,0,0"/>
    </Grid>
</UserControl>
