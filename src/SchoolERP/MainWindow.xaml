<Window x:Class="SchoolERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SchoolERP.Controls"
        xmlns:local="clr-namespace:SchoolERP"
        xmlns:views="clr-namespace:SchoolERP.Views"
        Title="School ERP - Dashboard"
        Height="860"
        Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DataTemplate x:Key="DashboardTemplate">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate x:Key="StudentsTemplate">
            <views:StudentListView/>
        </DataTemplate>
        <DataTemplate x:Key="FeesTemplate">
            <views:FeesView/>
        </DataTemplate>
        <DataTemplate x:Key="FinanceTemplate">
            <views:FinanceView/>
        </DataTemplate>
        <DataTemplate x:Key="AttendanceTemplate">
            <views:AttendanceView/>
        </DataTemplate>
        <DataTemplate x:Key="StaffTemplate">
            <views:StaffListView/>
        </DataTemplate>
        <DataTemplate x:Key="ReportsTemplate">
            <views:ReportsView/>
        </DataTemplate>

                <local:PageTemplateSelector x:Key="PageTemplateSelector"
                                                                        DashboardTemplate="{StaticResource DashboardTemplate}"
                                                                        StudentsTemplate="{StaticResource StudentsTemplate}"
                                                                        FeesTemplate="{StaticResource FeesTemplate}"
                                                                        FinanceTemplate="{StaticResource FinanceTemplate}"
                                                                        AttendanceTemplate="{StaticResource AttendanceTemplate}"
                                                                        StaffTemplate="{StaticResource StaffTemplate}"
                                                                        ReportsTemplate="{StaticResource ReportsTemplate}" />

                <Style x:Key="PageContentStyle"
                           TargetType="ContentControl">
                        <Setter Property="ContentTemplateSelector"
                                        Value="{StaticResource PageTemplateSelector}" />
                </Style>

        <Style x:Key="SidebarButtonStyle"
                TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Foreground"
                    Value="#334155"/>
            <Setter Property="FontSize"
                    Value="16"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Padding"
                    Value="14,12"/>
            <Setter Property="Margin"
                    Value="0,5,0,5"/>
            <Setter Property="Height"
                    Value="46"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#EAF0F8"/>
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="#D5DEE9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10.5"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Foreground"
                    Value="#6B7280"/>
            <Setter Property="Margin"
                    Value="4,10,0,8"/>
            <Setter Property="TextWrapping"
                    Value="Wrap"/>
        </Style>

        <Style x:Key="BodyCardStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="CornerRadius"
                    Value="22"/>
            <Setter Property="Padding"
                    Value="22"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                            ShadowDepth="0"
                            Opacity="0.10"
                            Color="#0B1020"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#001A3F"
                CornerRadius="26"
                Padding="22,18"
                Margin="0,0,0,18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                                        <Border Width="44"
                                                        Height="44"
                                                        Background="Transparent"
                                                        Margin="0,0,14,0">
                                                <controls:SchoolLogo Width="44" Height="44" />
                                        </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GRAMMAR PUBLIC SCHOOL, GHAZIKOT, MANSEHRA"
                                Foreground="White"
                                FontSize="24"
                                FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal"
                                Margin="0,4,0,0">
                            <TextBlock Text="{Binding WelcomeMessage}"
                                    Foreground="#D6E2F2"
                                    FontSize="12.5"/>
                            <TextBlock Text="   Finance • Attendance • Students • Staff"
                                    Foreground="#9FB2CD"
                                    FontSize="12.5"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                    CornerRadius="24"
                                        Padding="18"
                    Grid.Column="0">
                                <StackPanel>
                    <TextBlock Text="Navigation"
                                                        Foreground="#6B7280"
                                                        FontSize="10.5"
                                                        FontWeight="Bold"
                                                        Margin="4,2,0,8"/>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Dashboard">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Dashboard">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Students">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Students">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Students" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Fees">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Fees">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xEAFD;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Fees" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Finance">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Finance">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Finance" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Attendance">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Attendance">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Attendance" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Staff">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Staff">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Staff" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                                        <Button Command="{Binding Navigation.NavigateCommand}"
                                                        CommandParameter="Reports">
                                                <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Navigation.CurrentPage}" Value="Reports">
                                                                                <Setter Property="Background" Value="#EAF0F8"/>
                                                                                <Setter Property="Foreground" Value="#001A3F"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="Reports" VerticalAlignment="Center"/>
                                                </StackPanel>
                                        </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1"
                        Style="{StaticResource BodyCardStyle}">
                                        <ContentControl Content="{Binding Navigation.CurrentPage}"
                                                                        Style="{StaticResource PageContentStyle}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
