<Window x:Class="SchoolERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School ERP - Dashboard"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A" CornerRadius="20" Padding="24" Margin="0,0,0,24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="School ERP Dashboard" FontSize="28" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="WelcomeTextBlock" Text="Welcome" Foreground="#CBD5E1" Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#94A3B8" Text="Finance • Attendance • Students • Staff" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="20" Padding="20" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Navigation" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,16" />
                    <TextBlock Text="Dashboard" Foreground="#0F172A" Margin="0,0,0,12" />
                    <TextBlock Text="Students" Foreground="#0F172A" Margin="0,0,0,12" />
                    <TextBlock Text="Fees" Foreground="#0F172A" Margin="0,0,0,12" />
                    <TextBlock Text="Attendance" Foreground="#0F172A" Margin="0,0,0,12" />
                    <TextBlock Text="Reports" Foreground="#0F172A" Margin="0,0,0,12" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="28">
                <StackPanel>
                    <TextBlock Text="Signed in successfully." FontSize="24" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="This is the first dashboard shell after login. Next we will wire modules into these sections." Foreground="#475569" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
