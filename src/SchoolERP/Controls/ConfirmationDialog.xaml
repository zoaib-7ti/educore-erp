<Window x:Class="SchoolERP.Controls.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        FontFamily="Segoe UI"
        MinWidth="380"
        MaxWidth="520">
    <Border Background="White"
            CornerRadius="18"
            Padding="28"
            Margin="16">
        <StackPanel>
            <TextBlock Text="&#xE7BA;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="32"
                       Foreground="#DC2626"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14"/>
            <TextBlock x:Name="MessageTextBlock"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Foreground="#0F172A"
                       TextAlignment="Center"
                       Margin="0,0,0,24"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Cancel"
                        Width="110"
                        Height="40"
                        Margin="0,0,10,0"
                        Background="#F1F5F9"
                        Foreground="#334155"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CancelButton_Click"/>
                <Button Content="Delete"
                        Width="110"
                        Height="40"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
